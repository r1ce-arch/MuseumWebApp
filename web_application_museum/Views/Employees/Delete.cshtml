@model MuseumWebApp.Models.Employee
@{
    ViewData["Title"] = "Удалить сотрудника";
}
<h1>Удалить сотрудника</h1>
<h3>Вы уверены, что хотите удалить этого сотрудника?</h3>
<dl class="row">
    <dt class="col-sm-2">ФИО</dt>
    <dd class="col-sm-10">@Model.FullName</dd>
    <dt class="col-sm-2">Должность</dt>
    <dd class="col-sm-10">@Model.Position?.Title</dd>
    <dt class="col-sm-2">Дата найма</dt>
    <dd class="col-sm-10">@Model.HireDate.ToShortDateString()</dd>
    <dt class="col-sm-2">Логин</dt>
    <dd class="col-sm-10">@Model.Login</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Удалить" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>
