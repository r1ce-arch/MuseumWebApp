@model MuseumWebApp.Models.Tour
@{
    ViewData["Title"] = "Details";
}
<h1>Details</h1>
<dl class="row">
    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Price</dd>
    <dt class="col-sm-2">Duration</dt>
    <dd class="col-sm-10">@Model.Duration</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> | <a asp-action="Index">Back</a>