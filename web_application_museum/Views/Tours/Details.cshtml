@model MuseumWebApp.Models.Tour
@{
    ViewData["Title"] = "Детали экскурсии";
}
<h1>Детали экскурсии</h1>
<dl class="row">
    <dt class="col-sm-2">Название</dt>
    <dd class="col-sm-10">@Model.Title</dd>
    <dt class="col-sm-2">Описание</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Цена</dt>
    <dd class="col-sm-10">@Model.Price.ToString("N0") ₽</dd>
    <dt class="col-sm-2">Длительность</dt>
    <dd class="col-sm-10">@((int)Model.Duration.TotalHours) ч.</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.Id">Изменить</a> | <a asp-action="Index">Назад к списку</a>
