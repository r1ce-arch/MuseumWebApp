@model MuseumWebApp.Models.Tour
@{
    ViewData["Title"] = "Редактировать экскурсию";
    int currentHours = ViewBag.DurationHours != null ? (int)ViewBag.DurationHours : (int)Model.Duration.TotalHours;
}
<h1>Редактировать экскурсию</h1>
<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Title">Название</label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Description">Описание</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="form-group">
        <label asp-for="Price">Цена (₽)</label>
        <div class="input-group">
            <input asp-for="Price" class="form-control" type="number" min="0" step="0.01" />
            <span class="input-group-text">₽</span>
        </div>
    </div>
    <div class="form-group">
        <label for="durationHours">Длительность (часов)</label>
        <div class="input-group">
            <input type="number" name="durationHours" id="durationHours" class="form-control"
                   min="1" max="24" value="@currentHours" />
            <span class="input-group-text">ч.</span>
        </div>
        <span class="text-danger">@Html.ValidationMessage("durationHours")</span>
    </div>
    <div class="form-group mt-2">
        <input type="submit" value="Сохранить" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
    </div>
</form>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
