@model IEnumerable<MuseumWebApp.Models.Tour>
@{
    ViewData["Title"] = "Экскурсии";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Экскурсии</h1>
    <a asp-action="Create" class="btn btn-primary">Создать</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:18%">Название</th>
                        <th>Описание</th>
                        <th style="width:10%">Цена</th>
                        <th style="width:12%">Длительность</th>
                        <th style="width:1%"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold align-middle">@item.Title</td>
                            <td class="td-desc align-middle text-muted">@item.Description</td>
                            <td class="align-middle">@item.Price.ToString("N0") ₽</td>
                            <td class="align-middle">@((int)item.Duration.TotalHours) ч.</td>
                            <td class="text-end text-nowrap align-middle">
                                <a asp-action="Edit"    asp-route-id="@item.Id">Изменить</a> |
                                <a asp-action="Details" asp-route-id="@item.Id">Детали</a> |
                                <a asp-action="Delete"  asp-route-id="@item.Id">Удалить</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
