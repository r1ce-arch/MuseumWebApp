@model IEnumerable<MuseumWebApp.Models.Tour>
@{
    ViewData["Title"] = "Экскурсии";
}
<h1>Экскурсии</h1>
<p><a asp-action="Create" class="btn btn-primary">Создать новую</a></p>
<table class="table table-striped">
    <thead><tr><th>Название</th><th>Описание</th><th>Цена</th><th>Длительность</th><th></th></tr></thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Description</td>
                <td>@item.Price</td>
                <td>@item.Duration</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>