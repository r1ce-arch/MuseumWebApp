@model MuseumWebApp.Models.Position
@{
    ViewData["Title"] = "Удалить должность";
}
<h1>Удалить должность</h1>
<h3>Вы уверены, что хотите удалить эту должность?</h3>
<dl class="row">
    <dt class="col-sm-2">Название</dt>
    <dd class="col-sm-10">@Model.Title</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Удалить" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>
