@{
    ViewData["Title"] = "Главная — Музейное управление";
}

<div class="container mt-4">
    <!-- Hero-блок -->
    <div class="hero-section text-center py-5 px-3 mb-5" style="background-color: #F5F2EB; border-radius: 24px;">
        <h1 class="display-4 fw-semibold" style="color: #2C3E2F;">Добро пожаловать в систему управления музеем</h1>
        <p class="lead mt-3" style="color: #5A6B5C;">Управляйте экскурсиями, билетами, сотрудниками и экспонатами в одном месте</p>
        <hr class="my-4" style="width: 80px; height: 3px; background-color: #A3C4BC; border: none; margin: 1.5rem auto;">
        <div class="mt-4">
            <a asp-controller="Tours" asp-action="Index" class="btn btn-lg px-4" style="background-color: #A3C4BC; color: white; border-radius: 30px;">Начать работу →</a>
        </div>
    </div>

    <!-- Карточки основных разделов -->
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-radius: 20px; background-color: #FFFFFF;">
                <div class="card-body py-4">
                    <div class="mb-3" style="font-size: 2.5rem;">🎟️</div>
                    <h5 class="card-title" style="color: #2C3E2F;">Экскурсии</h5>
                    <p class="card-text" style="color: #7F8C8D;">Создавайте и редактируйте экскурсии, устанавливайте цены и длительность.</p>
                    <a asp-controller="Tours" asp-action="Index" class="btn btn-sm mt-2" style="background-color: #E6EFEA; color: #2C3E2F; border-radius: 20px;">Перейти →</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-radius: 20px; background-color: #FFFFFF;">
                <div class="card-body py-4">
                    <div class="mb-3" style="font-size: 2.5rem;">📅</div>
                    <h5 class="card-title" style="color: #2C3E2F;">Расписание</h5>
                    <p class="card-text" style="color: #7F8C8D;">Планируйте экскурсии, назначайте гидов и время начала.</p>
                    <a asp-controller="TourSchedules" asp-action="Index" class="btn btn-sm mt-2" style="background-color: #E6EFEA; color: #2C3E2F; border-radius: 20px;">Перейти →</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-radius: 20px; background-color: #FFFFFF;">
                <div class="card-body py-4">
                    <div class="mb-3" style="font-size: 2.5rem;">🎫</div>
                    <h5 class="card-title" style="color: #2C3E2F;">Билеты</h5>
                    <p class="card-text" style="color: #7F8C8D;">Продавайте билеты, отмечайте оплату и отслеживайте посетителей.</p>
                    <a asp-controller="Tickets" asp-action="Index" class="btn btn-sm mt-2" style="background-color: #E6EFEA; color: #2C3E2F; border-radius: 20px;">Перейти →</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-radius: 20px; background-color: #FFFFFF;">
                <div class="card-body py-4">
                    <div class="mb-3" style="font-size: 2.5rem;">👥</div>
                    <h5 class="card-title" style="color: #2C3E2F;">Сотрудники</h5>
                    <p class="card-text" style="color: #7F8C8D;">Управляйте персоналом, должностями и учётными записями.</p>
                    <a asp-controller="Employees" asp-action="Index" class="btn btn-sm mt-2" style="background-color: #E6EFEA; color: #2C3E2F; border-radius: 20px;">Перейти →</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-radius: 20px; background-color: #FFFFFF;">
                <div class="card-body py-4">
                    <div class="mb-3" style="font-size: 2.5rem;">🏺</div>
                    <h5 class="card-title" style="color: #2C3E2F;">Экспонаты</h5>
                    <p class="card-text" style="color: #7F8C8D;">Добавляйте экспонаты, указывайте эпоху и привязывайте к экскурсиям.</p>
                    <a asp-controller="Exhibits" asp-action="Index" class="btn btn-sm mt-2" style="background-color: #E6EFEA; color: #2C3E2F; border-radius: 20px;">Перейти →</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-radius: 20px; background-color: #FFFFFF;">
                <div class="card-body py-4">
                    <div class="mb-3" style="font-size: 2.5rem;">⚙️</div>
                    <h5 class="card-title" style="color: #2C3E2F;">Должности</h5>
                    <p class="card-text" style="color: #7F8C8D;">Настраивайте должности сотрудников (экскурсовод, администратор и др.).</p>
                    <a asp-controller="Positions" asp-action="Index" class="btn btn-sm mt-2" style="background-color: #E6EFEA; color: #2C3E2F; border-radius: 20px;">Перейти →</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Небольшая статистика или цитата (опционально) -->
    <div class="mt-5 p-4 text-center" style="background-color: #F9F8F6; border-radius: 24px;">
        <p class="mb-0 fst-italic" style="color: #5A6B5C;">«Управление музеем начинается с удобного инструмента»</p>
    </div>
</div>