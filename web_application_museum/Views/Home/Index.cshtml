@{
    ViewData["Title"] = "Главная";
    var heroGif = "/images/grass.gif"; /* гифка фона hero-блока */
}

<style>
    .hero-block {
        position: relative;
        overflow: hidden;
        border-radius: 16px;
        background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
        border: 1px solid var(--border);
    }
    .hero-gif {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.15;
        pointer-events: none;
    }
    .hero-content {
        position: relative;
        z-index: 1;
        padding: 64px 40px;
    }
    .section-title {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-secondary);
        margin-bottom: 20px;
    }
    .nav-card {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: background 0.15s, transform 0.15s;
        text-decoration: none;
        color: var(--text-primary);
    }
    .nav-card:hover {
        background: var(--bg-surface-2);
        transform: translateY(-2px);
        color: var(--text-heading);
    }
    .nav-card-icon {
        font-size: 1.6rem;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-surface-2);
        border-radius: 8px;
        flex-shrink: 0;
    }
    .nav-card-title {
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--text-heading);
        margin-bottom: 2px;
    }
    .nav-card-desc {
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin: 0;
    }
</style>

<div class="container mt-4">

    <!-- Hero -->
    <div class="hero-block mb-5">
        @if (!string.IsNullOrEmpty(heroGif))
        {
            <img src="@heroGif" class="hero-gif" alt="" />
        }
        <div class="hero-content text-center">
            <p class="section-title">Добро пожаловать</p>
            <h1 class="display-5 fw-bold mb-3">Система управления музеем</h1>
            <p class="text-muted mb-4" style="max-width:480px; margin:0 auto;">
                Экскурсии, билеты, сотрудники и экспонаты — всё в одном месте
            </p>
            <a asp-controller="Tours" asp-action="Index" class="btn btn-primary px-5">
                Начать работу
            </a>
        </div>
    </div>

    <!-- Разделы -->
    <p class="section-title">Разделы</p>
    <div class="row g-3">
        @foreach (var item in new[] {
            new { Icon = "🎟️", Title = "Экскурсии",  Desc = "Цены, описания, длительность",     Ctrl = "Tours",         Act = "Index" },
            new { Icon = "📅", Title = "Расписание", Desc = "Гиды, даты и время начала",         Ctrl = "TourSchedules", Act = "Index" },
            new { Icon = "🎫", Title = "Билеты",     Desc = "Продажа и учёт посетителей",        Ctrl = "Tickets",       Act = "Index" },
            new { Icon = "👥", Title = "Сотрудники", Desc = "Персонал и учётные записи",         Ctrl = "Employees",     Act = "Index" },
            new { Icon = "🏺", Title = "Экспонаты",  Desc = "Коллекция с фото",                  Ctrl = "Exhibits",      Act = "Index" },
            new { Icon = "⚙️", Title = "Должности",  Desc = "Роли и структура персонала",        Ctrl = "Positions",     Act = "Index" },
        })
        {
            <div class="col-md-6 col-lg-4">
                <a asp-controller="@item.Ctrl" asp-action="@item.Act" class="nav-card">
                    <div class="nav-card-icon">@item.Icon</div>
                    <div>
                        <div class="nav-card-title">@item.Title</div>
                        <p class="nav-card-desc">@item.Desc</p>
                    </div>
                </a>
            </div>
        }
    </div>

</div>
