@model MuseumWebApp.Models.Exhibit
@{
    ViewData["Title"] = "Удалить экспонат";
}

<h1 class="h3">Удалить экспонат</h1>
<p class="text-muted mb-3">Вы уверены, что хотите удалить этот экспонат? Действие необратимо.</p>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="mb-3">
            <div class="fw-semibold">@Model.Name</div>
            <div class="text-muted">@Model.Era @if (Model.Year != null) { <span>· @Model.Year</span> }</div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Удалить</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>

