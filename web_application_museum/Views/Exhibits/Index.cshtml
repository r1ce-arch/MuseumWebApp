@model IEnumerable<MuseumWebApp.Models.Exhibit>
@{
    ViewData["Title"] = "Экспонаты";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Экспонаты</h1>
    <a asp-action="Create" class="btn btn-primary">Добавить</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">Фото</th>
                        <th>Название</th>
                        <th style="width:10%">Год</th>
                        <th style="width:1%"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">
                                @if (!string.IsNullOrEmpty(item.PhotoPath))
                                {
                                    <img src="@item.PhotoPath" alt="@item.Name" style="width:46px;height:46px;object-fit:cover;border-radius:6px;" />
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="fw-semibold align-middle">@item.Name</td>
                            <td class="align-middle text-muted">@item.Year</td>
                            <td class="text-end text-nowrap align-middle">
                                <a asp-action="Edit"    asp-route-id="@item.Id">Изменить</a> |
                                <a asp-action="Details" asp-route-id="@item.Id">Детали</a> |
                                <a asp-action="Delete"  asp-route-id="@item.Id">Удалить</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
