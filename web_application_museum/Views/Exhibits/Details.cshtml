@model MuseumWebApp.Models.Exhibit
@{
    ViewData["Title"] = "Экспонат";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-1">@Model.Name</h1>
        @if (Model.Year != null) { <div class="text-muted">@Model.Year г.</div> }
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Изменить</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (!string.IsNullOrEmpty(Model.PhotoPath))
        {
            <div class="mb-3">
                <img src="@Model.PhotoPath" alt="@Model.Name" style="max-height:300px;border-radius:10px;" />
            </div>
        }
        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted">Год</dt>
            <dd class="col-sm-9">@Model.Year</dd>

            <dt class="col-sm-3 text-muted">Описание</dt>
            <dd class="col-sm-9">@Model.Description</dd>
        </dl>
    </div>
</div>
