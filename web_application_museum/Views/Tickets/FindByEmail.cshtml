@{
    ViewData["Title"] = "Найти билеты по email";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-1">Мои билеты</h4>
                <p class="text-muted mb-4" style="font-size:0.85rem;">
                    Введите email, указанный при регистрации, чтобы найти свои билеты
                </p>

                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" name="email" id="email" class="form-control"
                               placeholder="example@mail.com" />
                        <span class="text-danger">@Html.ValidationMessage("email")</span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Найти билеты</button>
                </form>

                @if (ViewBag.NotFound == true)
                {
                    <div class="mt-3 p-3 text-center"
                         style="background:var(--bg-surface-2); border-radius:var(--radius); color:var(--text-secondary); font-size:0.85rem;">
                        Билеты по этому email не найдены
                    </div>
                }
            </div>
        </div>
    </div>
</div>
