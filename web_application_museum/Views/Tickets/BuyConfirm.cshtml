@model MuseumWebApp.Models.TourSchedule
@{
    ViewData["Title"] = "Подтверждение покупки";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-4">Подтверждение покупки</h4>

                <div class="mb-3 p-3" style="background:var(--bg-surface-2); border-radius:var(--radius);">
                    <div class="fw-bold" style="font-size:1.05rem;">@Model.Tour?.Title</div>
                    <div class="text-muted mt-1" style="font-size:0.85rem;">
                        📅 @Model.StartTime.ToString("dd.MM.yyyy HH:mm")
                        @if (Model.Guide != null) { <span> · 👤 @Model.Guide.FullName</span> }
                    </div>
                    @if (Model.Tour != null)
                    {
                        <div class="mt-2" style="font-size:1.1rem; font-weight:700; color:var(--accent);">
                            @Model.Tour.Price.ToString("N0") ₽
                        </div>
                    }
                </div>

                <p class="text-muted" style="font-size:0.82rem;">
                    После подтверждения вы получите уникальный код и QR-код билета.
                    Оплата производится на месте.
                </p>

                <form asp-action="BuyConfirm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="tourScheduleId" value="@Model.Id" />
                    <button type="submit" class="btn btn-primary w-100 mb-2">Подтвердить покупку</button>
                    <a asp-action="Buy" class="btn btn-outline-secondary w-100">Назад</a>
                </form>
            </div>
        </div>
    </div>
</div>
