@model IEnumerable<MuseumWebApp.Models.Ticket>
@{
    ViewData["Title"] = "Билеты";
}
<h1>Билеты</h1>
<p><a asp-action="Create" class="btn btn-primary">Продать билет</a></p>
<table class="table">
    <thead>
        <tr><th>Экскурсия</th><th>Посетитель</th><th>Дата продажи</th><th>Оплачен</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TourSchedule?.Tour?.Title</td>
                <td>@item.VisitorName</td>
                <td>@item.SaleDate</td>
                <td>@(item.IsPaid ? "Да" : "Нет")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>