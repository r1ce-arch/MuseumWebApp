@model IEnumerable<MuseumWebApp.Models.Ticket>
@{
    ViewData["Title"] = "Билеты";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Билеты</h1>
    <a asp-action="Create" class="btn btn-primary">Продать билет</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Экскурсия</th>
                        <th>Посетитель</th>
                        <th>Дата продажи</th>
                        <th>Оплачен</th>
                        <th style="width:1%"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">@item.TourSchedule?.Tour?.Title</td>
                            <td class="align-middle">@item.VisitorName</td>
                            <td class="align-middle text-muted">@item.SaleDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="align-middle">@(item.IsPaid ? "Да" : "Нет")</td>
                            <td class="text-end text-nowrap align-middle">
                                <a asp-action="Edit"    asp-route-id="@item.Id">Изменить</a> |
                                <a asp-action="Details" asp-route-id="@item.Id">Детали</a> |
                                <a asp-action="Delete"  asp-route-id="@item.Id">Удалить</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
