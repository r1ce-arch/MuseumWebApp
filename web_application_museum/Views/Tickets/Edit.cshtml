@model MuseumWebApp.Models.Ticket
@{
    ViewData["Title"] = "Редактировать билет";
}
<h1>Редактировать билет</h1>
<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="TourScheduleId">Расписание экскурсии</label>
        <select asp-for="TourScheduleId" asp-items="ViewBag.TourScheduleId" class="form-control"></select>
    </div>
    <div class="form-group">
        <label asp-for="VisitorName">Имя посетителя</label>
        <input asp-for="VisitorName" class="form-control" />
    </div>
    <div class="form-group form-check">
        <input asp-for="IsPaid" class="form-check-input" />
        <label asp-for="IsPaid" class="form-check-label">Оплачен</label>
    </div>
    <div class="form-group mt-2">
        <input type="submit" value="Сохранить" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
    </div>
</form>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
