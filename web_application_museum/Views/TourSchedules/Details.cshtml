@model MuseumWebApp.Models.TourSchedule
@{
    ViewData["Title"] = "Детали расписания";
}
<h1>Детали</h1>
<dl class="row">
    <dt class="col-sm-2">Экскурсия</dt>
    <dd class="col-sm-10">@Model.Tour?.Title</dd>
    <dt class="col-sm-2">Гид</dt>
    <dd class="col-sm-10">@Model.Guide?.FullName</dd>
    <dt class="col-sm-2">Время начала</dt>
    <dd class="col-sm-10">@Model.StartTime</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.Id">Редактировать</a> | <a asp-action="Index">Назад к списку</a>