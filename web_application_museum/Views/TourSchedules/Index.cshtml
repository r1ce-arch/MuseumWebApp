@model IEnumerable<MuseumWebApp.Models.TourSchedule>
@{
    ViewData["Title"] = "Расписание экскурсий";
}
<h1>Расписание экскурсий</h1>
<p><a asp-action="Create" class="btn btn-primary">Добавить расписание</a></p>
<table class="table">
    <thead><tr><th>Экскурсия</th><th>Гид</th><th>Время начала</th><th></th></tr></thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Tour?.Title</td>
                <td>@item.Guide?.FullName</td>
                <td>@item.StartTime</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>