@model IEnumerable<MuseumWebApp.Models.TourSchedule>
@{
    ViewData["Title"] = "Расписание экскурсий";
    bool isAdmin = User.IsInRole("Admin") || User.IsInRole("Employee");
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Расписание экскурсий</h1>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-primary">Добавить</a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Экскурсия</th>
                        <th>Гид</th>
                        <th>Время начала</th>
                        <th style="width:1%"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold align-middle">@item.Tour?.Title</td>
                            <td class="align-middle text-muted">@item.Guide?.FullName</td>
                            <td class="align-middle text-muted">@item.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end text-nowrap align-middle">
                                @if (isAdmin)
                                {
                                    <text>
                                    <a asp-action="Edit"    asp-route-id="@item.Id">Изменить</a> |
                                    <a asp-action="Details" asp-route-id="@item.Id">Детали</a> |
                                    <a asp-action="Delete"  asp-route-id="@item.Id">Удалить</a>
                                    </text>
                                }
                                else
                                {
                                    <a asp-action="Details" asp-route-id="@item.Id">Подробнее</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
