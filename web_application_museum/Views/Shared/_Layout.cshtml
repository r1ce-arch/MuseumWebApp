<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Музей</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/web_application_museum.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Музей</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @* Меню зависит от роли *@
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tours" asp-action="Index">Экскурсии</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TourSchedules" asp-action="Index">Расписание</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tickets" asp-action="Index">Билеты</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Employees" asp-action="Index">Сотрудники</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Positions" asp-action="Index">Должности</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Exhibits" asp-action="Index">Экспонаты</a>
                            </li>
                        }
                        else if (User.IsInRole("Visitor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tours" asp-action="Index">Экскурсии</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TourSchedules" asp-action="Index">Расписание</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tickets" asp-action="MyTickets">Мои билеты</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tours" asp-action="Index">Экскурсии</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TourSchedules" asp-action="Index">Расписание</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tickets" asp-action="FindByEmail">Мои билеты</a>
                            </li>
                        }
                    </ul>

                    @* Правая часть навбара: вход / имя пользователя *@
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown">
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end"
                                    style="background:var(--bg-surface-2); border-color:var(--border);">
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item"
                                                    style="color:var(--text-primary);">
                                                Выйти
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm ms-2 my-auto"
                                   asp-controller="Account" asp-action="Login">
                                    Войти
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Музей -
            <a asp-controller="Home" asp-action="Privacy">Конфиденциальность</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
